```gitignore
# ==========================================
# Operating System Files
# ==========================================

.DS_Store
Thumbs.db
desktop.ini

# ==========================================
# Visual Studio Code
# ==========================================

.vscode/

# ==========================================
# JetBrains IDEs
# ==========================================

.idea/

# ==========================================
# Logs
# ==========================================

*.log

# ==========================================
# Temporary Files
# ==========================================

*.tmp
*.temp

# ==========================================
# Environment Files
# ==========================================

.env
.env.local

# ==========================================
# Node Modules (for future upgrades)
# ==========================================

node_modules/

# ==========================================
# Package Locks
# ==========================================

package-lock.json
yarn.lock
pnpm-lock.yaml

# ==========================================
# Build Folders
# ==========================================

dist/
build/

# ==========================================
# Cache
# ==========================================

.cache/
```
